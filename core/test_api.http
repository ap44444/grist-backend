### 1. Login to Production
POST https://grist-diet-app-production.up.railway.app/api/login/
Content-Type: application/json

{
  "username": "andy_jonson",
  "password": "20080903Mahee!"
}

> {%
    client.global.set("prod_token", response.body.access);
    client.log("✅ Step 1: Token Saved!");
%}

### 2. Generate a Production Lunch
GET https://grist-diet-app-production.up.railway.app/api/recipe/request/?type=lunch
Authorization: Bearer {{prod_token}}

> {%
    client.global.set("prod_meal_id", response.body.recipe_id);
    client.global.set("prod_ingredient", response.body.ingredients[0].name);
    client.log("✅ Step 2: Meal Generated!");
%}

### 3. Get Production Meal Slot ID
GET https://grist-diet-app-production.up.railway.app/api/plan/today/
Authorization: Bearer {{prod_token}}

> {%
    var meals = response.body.meals;
    for (var i = 0; i < meals.length; i++) {
        if (meals[i].type_code === "L") {
            client.global.set("prod_slot_id", meals[i].id);
            client.log("✅ Step 3: Slot ID Found!");
            break;
        }
    }
%}

### 4. Execute the Substitution
POST https://grist-diet-app-production.up.railway.app/api/meals/{{prod_slot_id}}/substitute/
Authorization: Bearer {{prod_token}}
Content-Type: application/json

{
  "ingredient_to_replace": "{{prod_ingredient}}"
}